# 知著 PenMark 环境配置示例
# 复制本文件为 .env 并修改为真实值

# ============ 数据库配置 ============

# PostgreSQL 连接字符串（网页生产模式必填）
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# 示例：postgresql://penmark:yourpassword@127.0.0.1:5432/penmark
DATABASE_URL=

# PostgreSQL SSL 配置
# true   = 启用 SSL 并验证证书（推荐生产环境）
# false  = 不使用 SSL
# disable = 启用 SSL 但不验证证书（仅开发测试，不推荐生产）
# PGSSL=true

# 连接池参数（可选，有默认值）
# PGPOOL_MAX=10
# PG_IDLE_TIMEOUT_MS=30000
# PG_CONNECTION_TIMEOUT_MS=5000

# 桌面版或本地开发可用 SQLite（显式声明，不用于生产）
# PENMARK_DB=sqlite

# ============ 安全配置 ============

# Token 签名密钥（请改为随机长字符串，至少 32 位）
PENMARK_SECRET=penmark-please-change-this-secret-to-a-long-random-string

# ============ 管理员配置 ============

# 首次启动时自动初始化管理员账号（仅在数据库无管理员时创建，不会覆盖已有密码）
# 如需重置密码请使用：npm run admin:reset-password
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
ADMIN_NICKNAME=管理员

# ============ 服务配置 ============

# 监听端口和地址
# PORT=3001
# PENMARK_HOST=0.0.0.0

# Nginx 反向代理时需要设置（1=信任一级代理，all=信任所有，loopback=信任本机）
# TRUST_PROXY=1

# 网页对外访问地址，用于反向代理后的同源/CSRF 校验；多个地址用逗号分隔
# 生产部署强烈建议填写，例如：https://note.example.com
# APP_ORIGIN=https://note.example.com

# 登录速率限制（每 IP 每分钟最大尝试次数，默认 10）
# LOGIN_RATE_LIMIT=10

# ============ AI 配置（可选） ============

# AI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
# AI_LAYOUT_MAX_INPUT=120000
# AI_CONTEXT_MAX_CHARS=24000

# ============ 运行模式 ============

# 生产模式必须设置
# NODE_ENV=production
