# 知著 PenMark 环境配置示例
# 复制本文件为 .env 并修改为真实值

# Token 签名密钥（请改为随机长字符串）
PENMARK_SECRET=penmark-please-change-this-secret-to-a-long-random-string

# 管理员账号（首次启动自动初始化，之后可在此修改密码并重启）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
ADMIN_NICKNAME=管理员


# AI configuration (DeepSeek by default; OpenAI-compatible providers can set AI_BASE_URL and AI_MODEL)
# AI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
# AI_LAYOUT_MAX_INPUT=120000
# AI_CONTEXT_MAX_CHARS=24000
